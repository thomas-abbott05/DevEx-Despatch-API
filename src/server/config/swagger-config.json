{
  "openapi": "3.0.0",
  "info": {
    "title": "DevEx Despatch API",
    "version": "v1",
    "description": "API for handling Category 2 - Despatch related documents. A valid API key is required to access the endpoints, please contact a team member using https://unswcse.atlassian.net/wiki/spaces/DevEx/pages/1431896088/Team+Roles."
  },
  "servers": [
    {
      "url": "https://devex.cloud.tcore.network",
      "description": "DevEx Despatch API Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "api-key",
        "description": "API key required to authenticate all requests. Contact a team member to obtain one."
      }
    },
    "schemas": {
      "CreateDespatchAdviceResponse": {
        "type": "object",
        "properties": {
          "advice-id": {
            "type": "string",
            "description": "The unique identifier of the newly created despatch advice.",
            "example": "507f1f77bcf86cd799439011"
          },
          "executed-at": {
            "type": "integer",
            "description": "Unix timestamp (seconds) of when the request was executed.",
            "example": 1734567890
          }
        },
        "required": ["advice-id", "executed-at"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "description": "A message describing what went wrong.",
            "example": "Request body must contain raw XML data"
          }
        },
        "required": ["success", "error"]
      }
    }
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "summary": "Returns health information",
        "description": "An endpoint that returns the health status of the API",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "healthy"
                    },
                    "uptime": {
                      "type": "integer",
                      "example": 3600
                    },
                    "version": {
                      "type": "string",
                      "example": "v1"
                    },
                    "timestamp": {
                      "type": "integer",
                      "example": 1734567890
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Internal Server Error"
                    },
                    "message": {
                      "type": "string",
                      "example": "An unexpected error occurred while processing the request."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/despatch/create": {
      "post": {
        "summary": "Create a new despatch advice",
        "description": "Accepts a UBL 2.1 DespatchAdvice XML document, validates it, and persists it. Returns the unique identifier assigned to the new record.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "in": "header",
            "name": "api-key",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key used to authenticate the request."
          }
        ],
        "requestBody": {
          "required": true,
          "description": "A valid UBL 2.1 DespatchAdvice XML document. Maximum size is 5 MB.",
          "content": {
            "application/xml": {
              "schema": {
                "type": "string",
                "description": "Raw UBL 2.1 DespatchAdvice XML document.",
                "example": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<DespatchAdvice xmlns=\"urn:oasis:names:specification:ubl:schema:xsd:DespatchAdvice-2\">\n  <ID>DA-001</ID>\n  <IssueDate>2026-03-11</IssueDate>\n  <DespatchSupplierParty>\n    <Party>\n      <PartyName><Name>Supplier Co.</Name></PartyName>\n    </Party>\n  </DespatchSupplierParty>\n  <DeliveryCustomerParty>\n    <Party>\n      <PartyName><Name>Buyer Co.</Name></PartyName>\n    </Party>\n  </DeliveryCustomerParty>\n  <Shipment>\n    <ID>SHIP-001</ID>\n  </Shipment>\n</DespatchAdvice>"
              }
            },
            "text/xml": {
              "schema": {
                "type": "string",
                "description": "Raw UBL 2.1 DespatchAdvice XML document."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Despatch advice successfully created.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateDespatchAdviceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Returned when the API key header is missing, the request body is empty or not XML, the Content-Type is invalid, or the XML content fails despatch advice validation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missingApiKey": {
                    "summary": "Missing API key header",
                    "value": {
                      "success": false,
                      "error": "Missing required header: api-key"
                    }
                  },
                  "missingBody": {
                    "summary": "Missing or empty request body",
                    "value": {
                      "success": false,
                      "error": "Request body must contain raw XML data"
                    }
                  },
                  "invalidContentType": {
                    "summary": "Invalid Content-Type header",
                    "value": {
                      "success": false,
                      "error": "Content-Type must be application/xml or text/xml"
                    }
                  },
                  "validationFailure": {
                    "summary": "Despatch advice XML validation failed",
                    "value": {
                      "success": false,
                      "error": "Despatch advice validation failed: Invalid XML content"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": "An unexpected error occurred while processing the request."
                }
              }
            }
          }
        }
      }
    },

    "/api/v1/despatch/cancel/order": {
      "post": {
        "summary": "Cancel existing despatch advice",
        "description": "Given a despatch advice ID and order cancellation document, mark the order as cancelled and update related database fields",
        "requestBody": {
          "required": true,
          "description": "A json body contain the despatch advice ID and order cancellation XML document",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "advice-id",
                  "order-cancellation-document"
                ],
                "properties": {
                  "advice-id": {
                    "type": "string",
                    "example": "e553cc8e-8b37-4a9b-a0cf-87c34ea70a35"
                  },
                  "order-cancellation-document": {
                    "type": "string",
                    "example": "<OrderCancellation>...</OrderCancellation>"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "order-cancellation": {
                      "type": "string",
                      "example": "<OrderCancellation>...</OrderCancellation>"
                    },
                    "order-cancellation-reason": {
                      "type": "string",
                      "example": "Refund requested"
                    },
                    "order-cancellation-id": {
                      "type": "string",
                      "example": "cfa1d364-b5a8-40e3-aad4-98e2be71263b"
                    },
                    "advice-id": {
                      "type": "string",
                      "example": "e553cc8e-8b37-4a9b-a0cf-87c34ea70a35"
                    },
                    "timestamp": {
                      "type": "integer",
                      "example": 1772246484
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Despatch advice or order cancellation not found for advice-id",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Not Found"
                    },
                    "message": {
                      "type": "string",
                      "example": "Failed to find Despatch Advice with id {advice-id}."
                    },
                    "timestamp": {
                      "type": "integer",
                      "example": 1772246484
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request, missing advice-id parameter, or order-cancellation-document failed validation for a proper order cancellation request by the buyer",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Bad Request"
                    },
                    "message": {
                      "type": "string",
                      "example": "Order Cancellation document failed validation."
                    },
                    "timestamp": {
                      "type": "integer",
                      "example": 1772246484
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorised, missing API key header",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Unauthorised"
                    },
                    "message": {
                      "type": "string",
                      "example": "Missing API key header."
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Provided API key doesnt match the owner of the resource",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Forbidden"
                    },
                    "message": {
                      "type": "string",
                      "example": "Unauthorised access."
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Internal Server Error"
                    },
                    "message": {
                      "type": "string",
                      "example": "An unexpected error occurred while processing the request."
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}