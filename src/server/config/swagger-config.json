{
  "openapi": "3.0.0",
  "info": {
    "title": "DevEx Despatch API",
    "version": "v1",
    "description": "API for handling Category 2 despatch documents and API key management."
  },
  "servers": [
    {
      "url": "https://devex.cloud.tcore.network",
      "description": "DevEx Despatch API Server"
    }
  ],
  "tags": [
    {
      "name": "Health"
    },
    {
      "name": "API Keys"
    },
    {
      "name": "Despatch"
    },
    {
      "name": "Despatch Cancellation"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Api-Key",
        "description": "API key sent in the Api-Key header."
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "healthy"
          },
          "uptime": {
            "type": "integer",
            "example": 3600
          },
          "version": {
            "type": "string",
            "example": "v1"
          },
          "executed-at": {
            "type": "integer",
            "example": 1772246484
          }
        },
        "required": ["status", "uptime", "version", "executed-at"]
      },
      "ErrorsArrayResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["Missing API key header. A valid key is required for this endpoint."]
          },
          "executed-at": {
            "type": "integer",
            "example": 1772246484
          }
        },
        "required": ["errors"]
      },
      "SuccessErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "example": "Request body must contain raw XML data"
          }
        },
        "required": ["success", "error"]
      },
      "CreateApiKeyRequest": {
        "type": "object",
        "required": ["teamName"],
        "properties": {
          "teamName": {
            "type": "string",
            "example": "team-despatch"
          }
        }
      },
      "CreateApiKeyResponse": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "example": "95f5ecde4f6f8b65e31c3d15d714f3a1f4f37d57a821fc8351568bc6a26fca5b"
          },
          "executed-at": {
            "type": "integer",
            "example": 1772246484
          }
        },
        "required": ["apiKey", "executed-at"]
      },
      "ApiKeyRecord": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "createdAt": {
            "type": "integer"
          }
        },
        "required": ["key", "owner", "createdAt"]
      },
      "ListApiKeysResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiKeyRecord"
            }
          },
          "executed-at": {
            "type": "integer"
          }
        },
        "required": ["results", "executed-at"]
      },
      "DeleteApiKeyResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          },
          "executed-at": {
            "type": "integer",
            "example": 1772246484
          }
        },
        "required": ["errors", "executed-at"]
      },
      "CreateDespatchAdviceResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "adviceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "executed-at": {
            "type": "integer",
            "example": 1772246484
          }
        },
        "required": ["success", "adviceIds", "executed-at"]
      },
      "ListDespatchAdvicesResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "advice-id": {
                  "type": "string",
                  "format": "uuid"
                },
                "despatch-advice": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "required": ["advice-id", "despatch-advice"]
            }
          },
          "executed-at": {
            "type": "integer",
            "example": 1772246484
          }
        },
        "required": ["results", "executed-at"]
      },
      "NotImplementedResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "example": "Not implemented yet"
          },
          "executed-at": {
            "type": "integer",
            "example": 1772246484
          }
        },
        "required": ["success", "error", "executed-at"]
      },
      "CancelOrderRequest": {
        "type": "object",
        "required": ["advice-id", "order-cancellation-document"],
        "properties": {
          "advice-id": {
            "type": "string",
            "format": "uuid",
            "example": "e553cc8e-8b37-4a9b-a0cf-87c34ea70a35"
          },
          "order-cancellation-document": {
            "type": "string",
            "example": "<OrderCancellation>...</OrderCancellation>"
          }
        }
      },
      "CancelOrderResponse": {
        "type": "object",
        "properties": {
          "order-cancellation": {
            "type": "string"
          },
          "order-cancellation-reason": {
            "type": "string",
            "example": "Refund requested"
          },
          "order-cancellation-id": {
            "type": "string",
            "format": "uuid"
          },
          "advice-id": {
            "type": "string",
            "format": "uuid"
          },
          "executed-at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-15T09:00:00.000Z"
          }
        },
        "required": [
          "order-cancellation",
          "order-cancellation-reason",
          "order-cancellation-id",
          "advice-id",
          "executed-at"
        ]
      }
    }
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Get API health",
        "responses": {
          "200": {
            "description": "Server health payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/api-key/create": {
      "post": {
        "tags": ["API Keys"],
        "summary": "Create a new API key",
        "description": "Creates an issued key tied to a team name. Requires the master key in Api-Key header.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateApiKeyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API key created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateApiKeyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing request body or teamName",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid master API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/api-key/list": {
      "get": {
        "tags": ["API Keys"],
        "summary": "List all API keys",
        "description": "Returns all issued API keys. Requires the master key in Api-Key header.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "All API keys",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListApiKeysResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid master API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/api-key/retrieve/{key}": {
      "get": {
        "tags": ["API Keys"],
        "summary": "Retrieve one API key",
        "description": "Returns key metadata by key value. Requires the master key in Api-Key header.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Key found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyRecord"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid master API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "404": {
            "description": "API key not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/api-key/delete/{key}": {
      "delete": {
        "tags": ["API Keys"],
        "summary": "Delete one API key",
        "description": "Deletes a key by key value. Requires the master key in Api-Key header.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Key deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteApiKeyResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid master API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "404": {
            "description": "API key not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/despatch/create": {
      "post": {
        "tags": ["Despatch"],
        "summary": "Create despatch advice records from order XML",
        "description": "Accepts order XML and may generate one or more despatch advice records.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "type": "string",
                "description": "Raw XML payload"
              }
            },
            "text/xml": {
              "schema": {
                "type": "string",
                "description": "Raw XML payload"
              }
            },
            "application/*+xml": {
              "schema": {
                "type": "string",
                "description": "Raw XML payload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Despatch advice created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateDespatchAdviceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing XML payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid issued API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/despatch/retrieve": {
      "get": {
        "tags": ["Despatch"],
        "summary": "Retrieve a despatch advice",
        "description": "Currently stubbed and returns not implemented.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "501": {
            "description": "Not implemented",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotImplementedResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid issued API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/despatch/list": {
      "get": {
        "tags": ["Despatch"],
        "summary": "List despatch advice records for the current API key",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of despatch advice records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListDespatchAdvicesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid issued API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/despatch/cancel/order": {
      "post": {
        "tags": ["Despatch Cancellation"],
        "summary": "Cancel an existing despatch advice",
        "description": "Cancels a despatch advice by advice-id using a cancellation XML document.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cancellation stored",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancelOrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "403": {
            "description": "API key does not own the despatch advice",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "404": {
            "description": "Despatch advice not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Despatch Cancellation"],
        "summary": "Retrieve order cancellation",
        "description": "Retrieves an order cancellation using advice-id or cancellation-id query parameters.",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "advice-id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Despatch advice id."
          },
          {
            "name": "cancellation-id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Cancellation id"
          }
        ],
        "responses": {
          "200": {
            "description": "Cancellation record",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CancelOrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "403": {
            "description": "API key does not own the despatch advice",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "404": {
            "description": "Cancellation not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorsArrayResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}